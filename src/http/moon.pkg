import {
  "moonbitlang/async/http" @async_http,
  "moonbitlang/async/io",
  "moonbitlang/async/js_async",
  "moonbitlang/core/json",
}

options(
  targets: {
    "http_js.mbt": [ "js" ],
    "http_native.mbt": [ "native" ],
    "http_wasm.mbt": [ "wasm" ],
    "http_wasmgc.mbt": [ "wasm-gc" ],
  },
)
